# ============================================================
# Copia este ficheiro para `.env` e preenche os valores reais.
# O `.env` está no .gitignore e nunca deve ser commitado.
# ============================================================

# --- PostgreSQL (TypeORM + docker-compose) ---
DATABASE_URL="postgresql://finapp:finapp@localhost:5432/controle_financeiro"
POSTGRES_USER=finapp
POSTGRES_PASSWORD=finapp
POSTGRES_DB=controle_financeiro

# --- Servidor ---
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- JWT (gera um segredo longo e aleatório; ex: openssl rand -hex 64) ---
JWT_SECRET=SUBSTITUI_ISTO_POR_UM_SEGREDO_LONGO_E_ALEATORIO

# --- Groq (cria a tua chave em https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

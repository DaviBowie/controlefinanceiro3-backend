# ============================================================
# Copia este ficheiro para `.env` e preenche os valores reais.
# O `.env` esta no .gitignore e nunca deve ser commitado.
# ============================================================

# --- PostgreSQL (usado pelo Prisma e pelo docker-compose) ---
DATABASE_URL="postgresql://finapp:finapp@localhost:5432/controle_financeiro?schema=public"
POSTGRES_USER=finapp
POSTGRES_PASSWORD=finapp
POSTGRES_DB=controle_financeiro

# --- Servidor ---
PORT=8000
FRONTEND_URL=http://localhost:5173

# --- Groq (cria a tua chave em https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
